# ── Supabase ─────────────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key"

# Service Role Key (NUNCA exponha no client — usada apenas pelo seed)
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"

# ── Site ─────────────────────────────────────────────────────────────────
# URL pública e canônica — base dos links enviados por e-mail (redefinição
# de senha). Em produção, use o domínio real (ex.: https://seu-app.com) e
# cadastre-o em: Supabase > Authentication > URL Configuration.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Banco de dados (Prisma) ──────────────────────────────────────────────
# Encontre em: Supabase Dashboard > Project Settings > Database > Connection string
# DATABASE_URL: connection pooling (porta 6543, pgbouncer)
# DIRECT_URL:   conexão direta (porta 5432) — usada em migrations/db push
DATABASE_URL="postgresql://postgres.SEU-PROJETO:SUA-SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.SEU-PROJETO:SUA-SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
