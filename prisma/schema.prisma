generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Perfil de acesso. As permissões de cada papel ficam centralizadas em
/// `lib/rbac/permissions.ts` — para adicionar RH/Supervisor/Gestor basta
/// incluir o valor aqui e mapear as permissões lá.
enum Role {
  admin
  employee

  // `role` é palavra reservada no PostgreSQL — daí o nome do tipo.
  @@map("user_role")
}

/// Usuário inativo mantém o histórico, mas não consegue autenticar.
enum UserStatus {
  active
  inactive

  @@map("user_status")
}

/// Perfil do colaborador.
///
/// A senha NÃO é armazenada aqui — o hash é responsabilidade do Supabase
/// Auth (`auth.users`). O perfil é resolvido pelo e-mail da sessão, então
/// o `id` é independente do id de `auth.users`.
model Profile {
  id           String       @id @default(uuid()) @db.Uuid
  nome         String
  email        String       @unique
  role         Role         @default(employee)
  status       UserStatus   @default(active)
  avatarUrl    String?      @map("avatar_url")
  cargo        String?
  departamento String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  timeRecords  TimeRecord[]
  locationEdits CompanyLocation[]

  @@index([role, status])
  @@map("profiles")
}

/// Área autorizada para bater ponto (geofence).
///
/// Tabela de linha única: `id` fixo em `SINGLETON` garante isso no banco,
/// em vez de depender de disciplina no código.
///
/// Enquanto NÃO existir uma linha aqui, o geofencing fica desligado e o
/// ponto funciona normalmente — do contrário, publicar este recurso
/// travaria a equipe inteira até alguém cadastrar a localização.
model CompanyLocation {
  id           String   @id @default("SINGLETON")
  latitude     Float
  longitude    Float
  /// Raio de tolerância, em metros.
  radiusMeters Int      @map("radius_meters")
  updatedAt    DateTime @updatedAt @map("updated_at")
  updatedById  String?  @map("updated_by_id") @db.Uuid
  updatedBy    Profile? @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("company_location")
}

/// Um registro de ponto por dia: `entrada` é preenchida no clock-in e
/// `saida` no clock-out do mesmo registro.
///
/// Cada batida guarda a prova de onde foi feita: coordenadas, precisão
/// do GPS, distância até a empresa (recalculada no servidor) e o
/// dispositivo. Nulos nos registros anteriores ao geofencing.
model TimeRecord {
  id        String    @id @default(uuid()) @db.Uuid
  profileId String    @map("profile_id") @db.Uuid
  entrada   DateTime
  saida     DateTime?
  createdAt DateTime  @default(now()) @map("created_at")

  entradaLat      Float?  @map("entrada_lat")
  entradaLng      Float?  @map("entrada_lng")
  entradaAccuracy Float?  @map("entrada_accuracy")
  entradaDistance Float?  @map("entrada_distance")
  entradaDevice   String? @map("entrada_device")

  saidaLat      Float?  @map("saida_lat")
  saidaLng      Float?  @map("saida_lng")
  saidaAccuracy Float?  @map("saida_accuracy")
  saidaDistance Float?  @map("saida_distance")
  saidaDevice   String? @map("saida_device")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, entrada])
  @@map("time_records")
}
